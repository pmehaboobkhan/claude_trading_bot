{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "approved_modes.yaml",
  "type": "object",
  "required": ["schema_version", "mode", "mode_set_at", "mode_set_by", "mode_set_reason", "history"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "mode": {
      "type": "string",
      "enum": ["RESEARCH_ONLY", "PAPER_TRADING", "LIVE_PROPOSALS", "LIVE_EXECUTION", "HALTED"]
    },
    "mode_set_at": { "type": "string", "format": "date-time" },
    "mode_set_by": { "type": "string", "minLength": 1 },
    "mode_set_reason": { "type": "string", "minLength": 1 },
    "history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["mode", "set_at", "set_by", "reason"],
        "additionalProperties": false,
        "properties": {
          "mode": { "type": "string" },
          "set_at": { "type": "string", "format": "date-time" },
          "set_by": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
