{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "watchlist.yaml",
  "type": "object",
  "required": ["schema_version", "universe", "benchmarks", "symbols"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "last_reviewed": { "type": "string", "format": "date" },
    "last_reviewed_by": { "type": "string" },
    "universe": { "type": "string", "minLength": 1 },
    "benchmarks": {
      "type": "object",
      "required": ["primary"],
      "additionalProperties": false,
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "secondary": { "type": "string", "minLength": 1 }
      }
    },
    "symbols": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "symbol",
          "company_name",
          "sector",
          "approved_for_research",
          "approved_for_paper_trading",
          "approved_for_live_trading",
          "max_position_size_pct"
        ],
        "additionalProperties": false,
        "properties": {
          "symbol": { "type": "string", "pattern": "^[A-Z]{1,5}$" },
          "company_name": { "type": "string", "minLength": 1 },
          "sector": { "type": "string", "minLength": 1 },
          "approved_for_research": { "type": "boolean" },
          "approved_for_paper_trading": { "type": "boolean" },
          "approved_for_live_trading": { "type": "boolean" },
          "max_position_size_pct": { "type": "number", "minimum": 0, "maximum": 100 },
          "max_position_size_usd": { "type": "number", "minimum": 0 },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
