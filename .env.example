# Calm Turtle environment variables — names only.
# Copy to .env.local for local development (gitignored).
# At runtime, Claude Code routine secrets take precedence over .env.local.
#
# Never commit a populated copy of this file.

# --- Broker: Alpaca paper (Phase 4+) ---
ALPACA_PAPER_KEY_ID=
ALPACA_PAPER_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# --- Broker: Alpaca live (Phase 8 only — hook-blocked until then) ---
ALPACA_LIVE_KEY_ID=
ALPACA_LIVE_SECRET_KEY=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# --- Notifications: Telegram ---
# Create a bot via @BotFather to get the token.
# Get your chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates after sending the bot a message.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
